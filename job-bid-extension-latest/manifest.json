{
  "manifest_version": 3,
  "name": "Job Bid — Quick Add & Bid",
  "version": "1.2.4",
  "description": "Add jobs and find the right resume to bid — directly from your browser sidebar.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "downloads",
    "downloads.shelf"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Job Bid",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
